// example lcvgc file

/* ブロックコメントの例 */

/*
  複数行の
  ブロックコメント
*/

/* ネスト対応
  /* 内側のコメント */
  外側に戻る
*/

tempo 125

scale c minor

device my_synth {
  port "IAC Driver"
}

instrument bass {
  device my_synth
  channel 1
}

instrument lead {
  device my_synth
  channel 2
}

kit tr808 {
  device my_synth
  kick {
    channel 10
    note c2
  }
  snare {
    channel 10
    note d2
  }
  hihat {
    channel 10
    note f2
  }
}

clip drums_a [bars 2] {
  use tr808
  resolution 16
  kick  x...x...x...x...
  snare ....x.......x...
  hihat x.x.x.x.x.x.x.x.
}

clip bass_a [bars 1] [scale c minor] {
  bass c:3:8 c:3:8 eb:3:8 f:3:4
}

scene verse {
  drums_a
  bass_a
  tempo +5
}

session my_song {
  verse [repeat 4]
}

play verse
stop
